# Biometric device (on the office LAN)
DEVICE_IP=192.168.1.201
DEVICE_PORT=4370
DEVICE_SERIAL=IDENTIX-001

# PocketBase server (the cloud EC2 URL in production)
PB_URL=https://attendance.example.com
PB_SERVICE_EMAIL=bridge@svc.local
PB_SERVICE_PASSWORD=change-me-strong-password

# How often to poll the device (seconds)
POLL_INTERVAL_SECONDS=60

# Local durable buffer / seen-punch marker
STATE_FILE=/var/lib/attendance-bridge/poller_state.json
